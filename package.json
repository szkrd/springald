{
  "name": "springald",
  "version": "1.0.1",
  "description": "Simple application launcher, similar to Launchy.",
  "author": "Szabolcs Kurdi",
  "license": "ISC",
  "main": "./dist/backend/backend.js",
  "type": "commonjs",
  "scripts": {
    "start": "electron .",
    "watch": "tsc -w",
    "clean": "rimraf dist",
    "build": "npm run clean && tsc",
    "dev": "electron . --development",
    "lint": "eslint src",
    "lint:fix": "eslint --fix src",
    "format": "prettier --write src"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.2.3",
    "electron": "40.4.1",
    "eslint": "10.0.0",
    "eslint-config-prettier": "10.1.8",
    "globals": "17.3.0",
    "prettier": "3.8.1",
    "rimraf": "6.1.3",
    "typescript": "5.9.3",
    "typescript-eslint": "8.56.1"
  }
}
