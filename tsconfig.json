{
  "compilerOptions": {
    "target": "es2024",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["dom", "ES2024"],
    "strict": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "inlineSourceMap": true
  },
  "include": ["src"]
}
