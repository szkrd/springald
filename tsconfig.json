{
  // This file helps neuter vscode ts warnings (thay are simply invalid and misleading),
  // tsc is NOT installed and shall not be, unless I migrate the project to ts!
  "compilerOptions": {
    "allowJs": true,
    "noImplicitAny": false,
    "checkJs": false, // TODO explore if I can enable this, it would be helpful, but so far the window.app namespace is in the way
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "target": "ES2022",
    "module": "commonjs", // to disable the require/import warning
    "ignoreDeprecations": "5.0"
  },
  "include": ["src"]
}
